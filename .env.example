# ─────────────────────────────────────────────────────────────────────────────
# iOS Widget — /api/widget-summary
# ─────────────────────────────────────────────────────────────────────────────

# Shared secret the iOS WidgetKit widget must send as the `x-widget-key` header
# to call GET /api/widget-summary. Requests without a matching value get 401.
# Generate a fresh random value (do NOT reuse this example):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WIDGET_API_KEY=replace-with-a-long-random-secret

# Average revenue per converted i-Sihat lead, in MYR. Used only to ESTIMATE ROAS
# for the widget — there is no real revenue-per-lead figure wired up yet, so the
# response is flagged `roas_estimated: true`. Defaults to 300 if unset.
ISIHAT_AVG_TREATMENT_VALUE=300
