{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/auth/verify", "destination": "/api/auth" },
    { "source": "/api/webhook/whatsapp", "destination": "/api/whatsapp-webhook" }
  ],
  "crons": [
    {
      "path": "/api/daily-tasks",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/alert-scheduler",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/daily-summary",
      "schedule": "30 1 * * *"
    }
  ]
}
